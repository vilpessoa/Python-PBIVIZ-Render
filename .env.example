# ─── Assistente TESS (enterprise) ──────────────────────────────────────────
# Credenciais lidas SOMENTE no servidor (Vercel Function / dev server).
# NUNCA prefixe com VITE_ — isso vazaria a chave no bundle do navegador.
# Em produção, configure no painel da Vercel (Settings → Environment Variables).
# Para dev local, copie este arquivo para .env.local (já ignorado pelo git).
TESS_API_KEY=
TESS_AGENT_ID=

# Liga/desliga a UI do assistente (opcional, default = true).
# VITE_TESS_ENABLED=true
