# ─── Assistente de IA (lado servidor) ──────────────────────────────────────
# Credenciais lidas SOMENTE no servidor (Vercel Function / dev server).
# NUNCA prefixe com VITE_ — isso vazaria a chave no bundle do navegador.
# Em produção, configure no painel da Vercel (Settings → Environment Variables).
# Para dev local, copie este arquivo para .env.local (já ignorado pelo git).

# Provedor de LLM ativo: tess | anthropic | gemini (default: tess).
# Troque aqui para mudar o modelo sem alterar código.
AI_PROVIDER=tess

# ── TESS (enterprise) ──
TESS_API_KEY=
TESS_AGENT_ID=

# ── Anthropic (Claude) — ao adicionar providers/anthropic.ts ──
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8

# ── Gemini — ao adicionar providers/gemini.ts ──
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# Liga/desliga a UI do assistente (opcional, default = true).
# VITE_TESS_ENABLED=true
